# ── Deployer ───────────────────────────────────────────────
# A funded testnet wallet's private key (NOT your personal/mainnet key).
# Generate a throwaway: `cast wallet new`  then fund it from a faucet.
PRIVATE_KEY=0xyour_deployer_private_key
DEPLOYER_ADDRESS=0xyour_deployer_address
CHAIN_NAME=base-sepolia

# ── RPC endpoints (testnet) ────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

