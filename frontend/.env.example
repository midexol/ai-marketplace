# MetaMask Embedded Wallets (Web3Auth)
# Sign up: https://dashboard.web3auth.io
# Create a project and copy the Client ID
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here
# Network must match your dashboard project: sapphire_devnet (free/new) or sapphire_mainnet (paid)
NEXT_PUBLIC_WEB3AUTH_NETWORK=sapphire_devnet

# Backend API — base origin only, no trailing /api (the client appends it)
# Local:      http://localhost:3001
# Production: https://synapse-ho59.onrender.com
NEXT_PUBLIC_API_URL=https://synapse-ho59.onrender.com
