# Environment
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database - Turso (SQLite serverless)
# Sign up: https://turso.tech
# Create a database: turso db create <name>
# Get token: turso db tokens create <name>
# For LOCAL dev you can omit both and it uses a ./synapse.db file automatically.
DATABASE_URL=libsql://your-db-xxxxx.turso.io
DATABASE_AUTH_TOKEN=eyJhbGc...

# Blockchain - Single Alchemy API key (works for all chains)
# Sign up: https://www.alchemy.com
# Create ONE app, get API key
# Automatically works for: Ethereum, Polygon, Arbitrum, Base
ALCHEMY_API_KEY=your_single_api_key

# LLM API - Venice (OpenAI-compatible). Optional — falls back to mock responses.
VENICE_API_KEY=your_venice_key_here

# CORS
CORS_ORIGIN=http://localhost:3000

# Smart Contracts (set after deployment)
AGENT_CONTRACT_ADDRESS=
MARKETPLACE_CONTRACT_ADDRESS=
GOVERNANCE_CONTRACT_ADDRESS=
